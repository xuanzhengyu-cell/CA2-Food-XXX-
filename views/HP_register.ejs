<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Document</title>
</head>
<body>
<%- include ('header/header.ejs')%>
<div class="container mt-6">
    <div class="card bg-white bg-opacity-75 border-0 shadow-sm p-4 ">
        <div>
            <h1>Registration</h1>
            <% if (messages && messages.length > 0) { %>
            <div class="alert alert-danger">
                <% messages.forEach(function(message) { %>
                    <p><%= message %></p>
                <% }); %>
            </div>
        <% } %>
        </div>
        <div>
            <form action="/register" method="post">
                <div class="mb-3 mt-3">
                    <label for="user">New Username:</label>
                    <input type="text" id="user" name="username" class="form-control" placeholder="Username" required>
                </div>
                <div class="mb-3 mt-3">
                    <label for="password">New Password:</label>
                    <input type="password" id="password" name="password" class="form-control" placeholder="Enter a Password" required>
                </div>
                <div class="mb-3 mt-3">
                    <label for="re_password">Confirm Password:</label>
                    <input type="password" id="re_password" name="re_password" class="form-control" placeholder="Re-enter the Password" required>
                </div>
                <div class="row">
                    <div class="col-md-2">
                        <div class="mb-3 mt-3">
                            <button type="submit" class="btn btn-light border-black border-2">Confirm Registration</button>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="mb-3 mt-3">
                            <a href="/login" class="btn btn-light border-black border-2">Cancel</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
</body>
</html>