<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Document</title>
</head>
<body>
    <%- include ('header/header.ejs') %>

        <!-- Profile Picture -->
    <div class="container mt-4">
        <% if (users.image == "null") { %>
            <img src="/images/nobody.jpg" alt="Profile Picture" width="150">
        <% } else { %>
            <img src="/images/<%= users.image %>" alt="Profile Picture" width="150">
        <% } %>
        <br>
        <hr>
    
        <!-- User Information -->
        <p>
            <h5>Name:</h5>
            <p><%= users.username %></p>
        </p>
        <p>
            <h5>Details:</h5>
            <p><%= users.details %></p>
        </p>
        <p>
            <h5>Locations Joined:</h5>
            <%= locations.length %>
        </p>
        <hr>

        <!-- User's Locations -->
        <h3>Locations</h3>
        <% if(locations.length === 0) { %>
            <p>This user has not joined any locations.</p>
        <% } else { %>
            <ul>
                <% locations.forEach(function(location){ %>
                    <li>
                        <a href="/location/<%= location.location_id %>">
                            <%= location.location_name %>
                        </a>
                        <% if (location.role === "group_owner"){ %>
                            <p> (Group Owner) </p> 
                        <% } else { %>
                            <p> (Group Member) </p>
                        <% } %>
                    </li>
                <% }) %>
            </ul>
        <% } %>
        <hr>

        <!-- Comment Button -->
        <a href="/user/<%= user_id %>/comment_create" class="btn btn-primary btn-sm mt-2">Add Comment</a>
        <hr>

        <!-- Comments -->
        <h3>Comments</h3>
        <% if(comments.length === 0){ %>
            <p>No comments yet.</p>
        <% } else { %>
            <% comments.forEach(function(comment){ %>
                <div>
                    <div class="border rounded p-2 mb-2">
                        <p>
                            <%= comment.comments_text %>
                        </p>
                        <p>
                            <%= comment.date %>
                        </p>
                    </div>
                    <% if (comment.owner_id == user.user_id || comment.sender_id == user.user_id || userRoles?.role == "admin") {%>
                        <a href="/user/<%= comment.owner_id %>/comment/edit/<%= comment.comments_id %>" class="btn btn-warning btn-sm">Edit Comment</a>

                        <form action="/user/<%= comment.owner_id %>/comment/delete/<%= comment.comments_id %>" method="POST" class="d-inline">
                            <button class="btn btn-danger btn-sm">
                                Delete Comment
                            </button>
                        </form>
                    <% } %>
                    <hr>
                </div>
            <% }) %>
        <% } %>
        <hr>
    </div>
</body>
</html>