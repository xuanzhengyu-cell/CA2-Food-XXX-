<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Comment</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
<%- include('header/header.ejs') %>

<div class="container mt-4">
    <h2>Edit Comment</h2>

    <form action="/comment/edit/<%= comment.comments_id %>" method="POST">

        <div class="mb-3">
            <label>Comment ID</label>
            <input
                type="text"
                class="form-control"
                value="<%= comment.comments_id %>"
                readonly>
        </div>

        <div class="mb-3">
            <label>Sender ID</label>
            <input
                type="text"
                class="form-control"
                value="<%= comment.sender_id %>"
                readonly>
        </div>

        <div class="mb-3">
            <label>Owner ID</label>
            <input
                type="text"
                class="form-control"
                value="<%= comment.owner_id %>"
                readonly>
        </div>

      
        <div class="mb-3">
            <label>Comment</label>
            <textarea
                name="comments_text"
                class="form-control"
                rows="5"
                required><%= comment.comments_text %></textarea>
        </div>

        <button type="submit" class="btn btn-success">
            Save Changes
        </button>

        <a href="/" class="btn btn-secondary">
            Cancel
        </a>

    </form>
</div>
</body>
</html>
