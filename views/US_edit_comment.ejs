<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Comment</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
<%- include('header/header.ejs') %>

<div class="container mt-4">
    <h2>Edit Comment</h2>

    <form action="/user/<%= comments.owner_id %>/comment/edit/<%= comments.comments_id %>" method="POST">
 
        <div class="mb-3">
            <label>Comment</label>
            <textarea
                name="comments_text"
                class="form-control"
                rows="5"
                required><%= comments.comments_text %></textarea>
        </div>

        <button type="submit" class="btn btn-success">
            Save Changes
        </button>

        <a href="/" class="btn btn-secondary">
            Cancel
        </a>

    </form>
</div>
</body>
</html>
