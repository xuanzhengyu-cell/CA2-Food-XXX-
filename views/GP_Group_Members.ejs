<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Location Members</title>
</head>
<body>
<%- include ('header/header.ejs') %>
<div class="container mt-4">
    <div>
        <h1>Members</h1>
    </div>
    <div>
        <form action="/request/location/<%= location_id %>" method="post">
            <button type="submit" class="btn btn-success mb-4">
                Register to join
        </button>
        </form>
    </div>
    <div>
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Username</th>
                    <th>Current Role</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user=> { %>
                    
                    <tr>
                        <td>
                            <a href="/user/<%= user.user_id %>" ><%= user.username %></a>
                        </td>

                        <td>
                            <% if (user.group_role === "group_owner") { %>
                                <h5>Group Owner</h5>
                            <% } else if (user.group_role === "group_member") { %>
                                <h5>Group Member</h5>
                            <% } else if (user.group_role === "normal_user") { %>
                                <h5>Normal User</h5>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

</body>
</html>