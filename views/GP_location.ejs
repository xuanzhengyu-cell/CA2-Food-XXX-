<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Document</title>
</head>
<body>
    <%- include ('header/header.ejs') %>
    <h1><%= location_name %></h1>

    <a href="/location/edit/<%= location_id %>" class="btn btn-warning">Group Owner Dashboard</a>
    <a href="/location_members/<%= location_id %>" class="btn btn-warning">Stalls at that Location</a>
    <a href="/location/<%= location_id %>/message" class="btn btn-success"> Add Message </a>

    <div class="card">
        <div class="card-body">

        <% if(messages.length === 0){ %>
            <p>No messages yet.</p>
        <% } %>

        <% messages.forEach(message => { %>

            <div class="border rounded p-3 mb-3">
                <h5><%= message.title %></h5>
                <p><%= message.text %></p>

                <br><br>

                <a href="/location/<%= message.location_id %>/message/edit/<%= message.messages_id %>"
                   class="btn btn-warning btn-sm">
                    Edit
                </a>

                <form action="/location/<%= location_id %>/message/delete/<%= message.messages_id %>"
                      method="POST"
                      class="d-inline">

                    <button class="btn btn-danger btn-sm">
                        Delete
                    </button>

                </form>
            </div>
        <% }) %>



        </div>
    </div>
</body>
</html>
