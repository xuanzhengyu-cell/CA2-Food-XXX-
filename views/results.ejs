<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Search Results</title>
</head>
<body>
<%- include ('header/header.ejs')%>
<div class="container mt-6">
    <div class="card bg-white bg-opacity-75 border-0 shadow-sm p-4">
        <h1>Search Results</h1>

        <%- include('searchbar', { filters: filters }) %>

        <% if (messages.length === 0) { %>
            <p>No results found.</p>
        <% } else { %>
            <% messages.forEach(function(message) { %>
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title"><%= message.location_name %></h5>
                        <h6 class="card-subtitle mb-2 text-muted">
                            Posted by <%= message.sender_name %> on <%= message.date %> &middot; <%= message.likes %> likes
                        </h6>
                        <p class="card-text"><%= message.text %></p>
                    </div>
                </div>
            <% }); %>
        <% } %>
    </div>
</div>
</body>
</html>

