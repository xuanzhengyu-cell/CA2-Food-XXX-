<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Create Message</title>
</head>
<body>
<%- include ('header/header.ejs')%>
    <h1>Create Location Message</h1>

    <form action="/location/<%= location_id %>/message_create" method="POST">
        <div>
            <h3> Title:</h3>
            <input type="text" id="title" name="title" required >
        </div>
        <br>
        <div>
            <h3>Message:</h3>
            <textarea id="content" name="content" rows="5" cols="40" required
            ></textarea>
        </div>
        <br>
        <button type="submit" class="btn btn-primary btn mt-2">Add Message</button>
    </form>
    <br>
    <a href="/location/<%= location_id %>" class="btn btn-primary btn mt-2">
        Back to Location
    </a>

</body>
</html>
