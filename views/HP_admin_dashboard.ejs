<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Document</title>
</head>
<body>
<%- include ('header/header.ejs')%>
    <div class="container mt-4">
        <h1>Admin Dashboard</h1>
        <br>
        <div class="card mb-4">

            <div class="card-header">
                <h3>Group List</h3>
            </div>

            <div class="card-body">
                <p>View all existing groups.</p>

                <a href="/groups" class="btn btn-primary">
                    See Group List
                </a>
            </div>
        </div>

        <div class="card mb-4">

            <div class="card-header">
                <h3>Users List</h3>
            </div>

            <div class="card-body">
                <p>View all existing users.</p>

                <a href="/users" class="btn btn-primary">
                    Edit Members
                </a>
            </div>
        </div>
    </div>
    <div class="container mt-4">
        <h3>Create Announcements</h3>
        <form action="/announcement" method="post">
            <textarea id="announcement" class="form-control" name="announcement" rows="5" cols="100" placeholder="Enter announcements here"><%= announcement.text%></textarea>
            <br>
            <button type="submit" class="btn btn-primary">Announce</button>
        </form>
        <br>
        <form action="/clear_announcement" method="post">
            <button type="submit" class="btn btn-primary">Clear</button>
        </form>
    </div>

</body>
</html>    
