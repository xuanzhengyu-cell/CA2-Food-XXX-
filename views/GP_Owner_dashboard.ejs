<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Group Owner Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<%- include('header/header.ejs') %>

<div class="container mt-4">
    <h2>Group: <%= location.location_name %></h2>

    <!-- Section 1: Location details -->
    <form action="/location/edit/<%= location.location_id %>" method="POST">
        <div class="mb-3">
            <label class="form-label">Location Name</label>
            <input type="text" name="location_name" class="form-control" value="<%= location.location_name %>" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Location Image</label>
            <input class="form-control" type="file" id="image" name="image" accept="image/*">
        </div>

        <button type="submit" class="btn btn-success mb-4">
            Save Changes
        </button>
    </form>

    <hr>

    <!-- Section 2: Manage Members -->
    <div class="mt-4">
        <h3>Edit Members</h3>
        <table class="table table-bordered table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Username</th>
                    <th>Current Role</th>
                    <th>Change Role</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr>
                        <td><%= user.username %></td>

                        <!-- Role Label -->
                        <% if (user.group_role === "group_owner") { %>
                            <td>
                                <h5>Group Owner</h5>
                            </td>
                        <% } else if (user.group_role === "group_member") { %>
                            <td>
                                <h5>Group Member</h5>
                            </td>
                        <% } else if (user.group_role === "normal_user") { %>
                            <td>
                                <h5>normal_user</h5>
                            </td>
                        <% } %>
                        

                        <!-- Change Role -->
                        <td>
                            <form action="/location/edit/<%= location.location_id %>/changeRole/<%= user.user_id %>" method="POST" class="d-flex gap-2">
                                <select name="role" class="form-select form-select-sm">
                                    <option value="group_owner" <%= user.group_role === "group_owner" ? "selected" : "" %>>
                                        Group Owner
                                    </option>
                                    <option value="group_member" <%= user.group_role === "group_member" ? "selected" : "" %>>
                                        Group Member
                                    </option>
                                    <option value="normal_user" <%= user.group_role === "normal_user" ? "selected" : "" %>>
                                        Normal User
                                    </option>
                                </select>
                                <button type="submit" class="btn btn-success btn-sm">Update</button>
                            </form>
                        </td>

                        <!-- Kick User! -->
                        <td>
                            <form action="/location/edit/<%= location.location_id %>/deleteUser/<%= user.user_id %>" method="POST">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Kick this user?')">
                                    Kick User
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <a href="/location/<%= location.location_id %>" class="btn btn-secondary mt-3">
        Exit Group Owner's Dashboard
    </a>
</div>

</body>
</html>