<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Document</title>
</head>
<body >
<%- include ('header/header.ejs')%>
<div class="container mt-3">
    <div class="card bg-white bg-opacity-75 border-0 shadow-sm p-4 ">
        <div>
            <h1>Login</h1>
            <% if (errors && errors.length > 0) { %>
                <div class="alert alert-danger">
                    <% errors.forEach(function(error) { %>
                        <p><%= error %></p>
                    <% }); %>
                </div>
            <% } %>
            <% if (messages && messages.length > 0) { %>
                <div class="alert alert-success">
                    <% messages.forEach(function(message) { %>
                        <p><%= message %></p>
                    <% }); %>
                </div>
            <% } %>
        </div>
        <div>
            <form action="/login" method="post">
                <div class="mb-3 mt-3">
                    <label for="username"><h5>Username:</h5></label>
                    <input type="name" id="username" name="username" class="form-control" placeholder="username" required>
                </div>
                <div class="mb-3 mt-3">
                    <label for="password"><h5>Password:</h5></label>
                    <input type="password" id="password" name="password" class="form-control" placeholder="password" required>
                </div>
                <div class="mb-3 mt-3">
                    <button type="submit" class="btn btn-light border-black border-2">Log In</button>
                </div>
            </form>
        </div>
        <div class="mb-3 mt-3">
            <h5>To register for a new account:</h5>
            <a href="/register">
                <button type="submit" class="btn btn-light border-black border-2">Registration</button>
            </a>
        </div>
    </div>
</div>
</body>
</html>