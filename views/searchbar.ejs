<!-- searchbar.ejs -->
<!-- A normal HTML form. Submitting it reloads the page with the
     filters added as ?search=...&location=... etc, which app.js
     reads with req.query -->

<form action="/stalls" method="GET">
  <input
    type="text"
    name="search"
    placeholder="Search by name..."
    value="<%= filters.search || '' %>"
  >

  <input
    type="text"
    name="location"
    placeholder="Location"
    value="<%= filters.location || '' %>"
  >

  <input
    type="text"
    name="cuisine"
    placeholder="Cuisine"
    value="<%= filters.cuisine || '' %>"
  >

  <select name="rating">
    <option value="">Any Rating</option>
    <option value="4" <%= filters.rating === '4' ? 'selected' : '' %>>4 stars & up</option>
    <option value="3" <%= filters.rating === '3' ? 'selected' : '' %>>3 stars & up</option>
    <option value="2" <%= filters.rating === '2' ? 'selected' : '' %>>2 stars & up</option>
  </select>

  <select name="price">
    <option value="">Any Price</option>
    <option value="$" <%= filters.price === '$' ? 'selected' : '' %>>$</option>
    <option value="$$" <%= filters.price === '$$' ? 'selected' : '' %>>$$</option>
    <option value="$$$" <%= filters.price === '$$$' ? 'selected' : '' %>>$$$</option>
  </select>

  <button type="submit">Search</button>
</form>
