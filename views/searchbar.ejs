<% var f = typeof filters !== 'undefined' ? filters : {}; %>

<form action="/search" method="GET" class="mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label for="location" class="form-label">Location</label>
            <input
                type="text"
                id="location"
                name="location"
                class="form-control"
                placeholder="Search by location name..."
                value="<%= f.location || '' %>"
            >
        </div>

        <div class="col-md-3">
            <label for="date" class="form-label">Posted on or after</label>
            <input
                type="date"
                id="date"
                name="date"
                class="form-control"
                value="<%= f.date || '' %>"
            >
        </div>

        <div class="col-md-3">
            <label for="likes" class="form-label">Minimum likes</label>
            <input
                type="number"
                id="likes"
                name="likes"
                class="form-control"
                min="0"
                placeholder="0"
                value="<%= f.likes || '' %>"
            >
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-light border-black border-2 w-100">Search</button>
        </div>
    </div>
</form>
