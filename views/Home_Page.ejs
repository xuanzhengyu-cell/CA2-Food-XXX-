<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
    ></script>

    <title>Foodie Lookie</title>

    <style>
        body {
            background-color: #f8f9fa;
        }

        .location-card {
            border: none;
            border-radius: 12px;
            overflow: hidden;
            transition: transform 0.2s ease,
                        box-shadow 0.2s ease;
        }

        .location-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 22px rgba(0, 0, 0, 0.18);
        }

        .location-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .location-name {
            font-size: 1.2rem;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <%- include('header/header.ejs') %>

    <div class="container mt-4">

        <h1 class="mb-3">Home Page</h1>
        <br>
        <div>
            <h3>Announcements</h3>
            <h4><%= announcments.text %></h4>
        </div>
        <br>
        <!-- Search bar -->
        <form action="/" method="GET" class="mb-4">

            <div class="row g-2">

                <div class="col-md-6">
                    <input
                        type="text"
                        name="search"
                        class="form-control"
                        placeholder="Search locations..."
                        value="<%= search %>"
                    >
                </div>

                <div class="col-md-2">
                    <button
                        type="submit"
                        class="btn btn-dark w-100"
                    >
                        Search
                    </button>
                </div>

            </div>

        </form>

        <!-- Location cards -->
        <% if (locations.length === 0) { %>

            <div class="alert alert-secondary">
                No locations found.
            </div>

        <% } else { %>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">

                <% locations.forEach(function(loc) { %>

                    <div class="col">

                        <div class="card location-card h-100 shadow-sm">

                            <% if (loc.image) { %>

                                <img
                                    src="/images/<%= loc.image %>"
                                    class="card-img-top location-image"
                                    alt="<%= loc.location_name %>"
                                >

                            <% } else { %>

                                <img
                                    src="https://placehold.co/600x400?text=No+Location+Image"
                                    class="card-img-top location-image"
                                    alt="No location image"
                                >

                            <% } %>

                            <div class="card-body d-flex flex-column">

                                <h5 class="card-title location-name">
                                    <%= loc.location_name %>
                                </h5>

                                <p class="card-text text-muted">
                                    View discussions and food recommendations
                                    for this location.
                                </p>

                                <a
                                    href="/location/<%= loc.location_id %>"
                                    class="btn btn-dark mt-auto"
                                >
                                    View Location
                                </a>

                            </div>

                        </div>

                    </div>

                <% }); %>

            </div>

        <% } %>

    </div>

</body>
</html>
