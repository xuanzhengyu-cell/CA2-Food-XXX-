<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Document</title>
</head>
<body>
    <%- include ('header/header.ejs') %>

    <div class="container mt-4">
        <h1>Home Page</h1>

        <!-- Admin messages go here (not part of the search feature) -->

        <!-- Search bar - filters the location cards below -->
        <form action="/" method="GET" class="mb-4">
            <div class="row g-2">
                <div class="col-md-4">
                    <input
                        type="text"
                        name="search"
                        class="form-control"
                        placeholder="Search locations..."
                        value="<%= search %>"
                    >
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-light border-black border-2 w-100">Search</button>
                </div>
            </div>
        </form>

        <!-- Location cards -->
        <div class="row row-cols-1 row-cols-md-4 g-3">
            <% if (locations.length === 0) { %>
                <p>No locations found.</p>
            <% } else { %>
                <% locations.forEach(function(loc) { %>
                    <div class="col">
                        <a href="/location/<%= loc.location_id %>" class="text-decoration-none">
                            <div class="card bg-dark text-white text-center h-100">
                                <div class="card-body d-flex align-items-center justify-content-center">
                                    <%= loc.location_name %>
                                </div>
                            </div>
                        </a>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>
</body>
</html>
