<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <title>Location Groups</title>
</head>

<body>
<%- include ('header/header.ejs') %>
<div class="container mt-5">
    <div>
        <h2>Create New Group</h2>
        <form action="/create_location" method="post" enctype="multipart/form-data">
            <input type="text" id="location_name" name="location_name" class="form-control" placeholder="Name of New Location" required>
            <br>
            <input class="form-control" type="file" id="image" name="image" accept="image/*" >
            <br>
            <select name="user_id" class="form-select">
            <% users.forEach(users => { %>
                <% if (users.role == "admin") { %>
                    <option value="<%= users.user_id %>" disabled>
                        <%= users.username %>
                    </option>
                <% } else {%>
                    <option value="<%= users.user_id %>" >
                        <%= users.username %>
                    </option>
                <% } %>
            <% }) %>
            </select>

            <button type="submit" class="btn btn-success btn-sm mt-2">Create New Location Group</button>
        </form>
    </div>
    <br><br>
    <div>
        <h2>Existing Groups</h2>

        <table class="table table-bordered table-hover">

            <thead class="table-dark">
                <tr>
                    <th width="100">Location Name</th>
                    <th width="100"></th>
                    <th width="100"></th>
                </tr>
            </thead>

            <tbody>

                <% locations.forEach(function(location) { %>

                    <tr>
                        <td><%= location.location_name %></td>
                        <td><a href="/location/edit/<%= location.location_id %>">Edit</a></td>
                        <td><form action="/delete_location/<%= location.location_id %>" method="POST" style="display:inline;">
                                <button type="submit" onclick="return confirm('Are you sure you want to delete this location?');">
                                    Delete
                                </button>
                            </form></td>

                    </tr>

                <% }); %>

            </tbody>

        </table>
    </div>
</div>

</body>
</html>
