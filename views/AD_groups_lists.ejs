<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Location Groups</title>
</head>

<body>
<%- include ('header/header.ejs') %>
<div class="container mt-5">

    <h2>Existing Groups</h2>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th width="100">Location Name</th>
                <th width="100"></th>
                <th width="100"></th>
            </tr>
        </thead>

        <tbody>

            <% locations.forEach(function(location) { %>

                <tr>
                    <td><%= location.location_name %></td>
                    <td><a href="/location/edit/<%= location.location_id %>">Edit</a></td>
                    <td><form action="/delete_location/<%= location.location_id %>" method="POST" style="display:inline;">
                            <button type="submit" onclick="return confirm('Are you sure you want to delete this location?');">
                                Delete
                            </button>
                        </form></td>

                </tr>

            <% }); %>

        </tbody>

    </table>

</div>

</body>
</html>
