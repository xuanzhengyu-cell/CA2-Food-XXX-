<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Document</title>
</head>
<body>
    <%- include ('header/header.ejs')%>

        <div class="container mt-4">
            <!-- User Name -->
            <div class="card mb-4">
                <div class="card-body text-center">
                    <h2>
                        <%= users.username %>
                    </h2>
                </div>
            </div>
            <br>

            <!-- User Details -->
            <div class="card mb-4">
                <div class="card-body">

                    <h4>Profile Information</h4>

                    <% if (users.image == "null") { %>
                        <img src="/images/nobody.jpg" alt="Profile Picture" width="150">
                    <% } else { %>
                        <img src="../images/<%= users.image %>" alt="Profile Picture" width="150">
                    <% } %>

                    <p><strong>Role:</strong>
                        <%= users.role %>
                    </p>

                    <% if(users.role==="admin" ){ %>

                        <p><strong>Status:</strong> Administrator</p>

                        <% } else { %>

                            <p><strong>Status:</strong> Normal User</p>

                            <% } %>

                </div>
            </div>

            <!-- Buttons -->
            <div class="container mb-3">
                <!-- edit button wzy -->
                <a href="/profile/edit" class="btn btn-warning">
                    Edit Profile
                </a>

                <!-- delete account idk whose is it write here. -->


                <a href="/logout">
                    <button type="submit" class="btn btn-light border-black border-2">Log Out</button>
                </a>
            </div>
        </div>
        <div class="container mb-3">
            <div class="card mb-4">
                <div class="card-body">
                    <h4>Comments</h4>
                    <% if (comments.length===0) { %>
                        <p>No comments.</p>

                    <% } else { %>
                        <% comments.forEach(comment=> { %>
                            <div class="border rounded p-2 mb-2">
                                <p>
                                    <%= comment.comments_text %>
                                    <br>
                                    <%= comment.date %>
                                </p>
                                <form action="/user/<%= comment.owner_id %>/comment/delete/<%= comment.comments_id %>" method="POST" class="d-inline">
                                    <button class="btn btn-danger btn-sm">
                                        Delete Comment
                                    </button>
                                </form>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
</body>
</html>
